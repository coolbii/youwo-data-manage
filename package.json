{
  "name": "@youwo-homework/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:client": "nx dev client",
    "dev:api": "if [ -f .env ]; then set -a; . ./.env; set +a; fi; nx serve api-java",
    "dev:api:docker": "export POSTGRES_PORT=${POSTGRES_PORT:-5433}; export SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:${POSTGRES_PORT}/youwo_homework; export SPRING_DATASOURCE_USERNAME=${SPRING_DATASOURCE_USERNAME:-postgres}; export SPRING_DATASOURCE_PASSWORD=${SPRING_DATASOURCE_PASSWORD:-postgres}; docker compose -f docker-compose.dev.yml up -d postgres && nx serve api-java",
    "build": "nx run-many -t build --projects=client,api-java",
    "lint": "nx run-many -t lint --projects=client,api-java",
    "lint:client": "nx lint client",
    "lint:api-java": "nx lint api-java",
    "test:api-java": "nx run api-java:test",
    "graphql:codegen": "nx run api-java:graphql-codegen",
    "graphql:check": "nx run api-java:graphql-drift-check",
    "db:migrate": "if [ -f .env ]; then set -a; . ./.env; set +a; fi; nx run api-java:db-migrate",
    "db:up": "docker compose -f docker-compose.dev.yml up -d postgres",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f postgres",
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.6.0",
    "@nx/eslint-plugin": "22.6.0",
    "@nx/express": "^22.6.0",
    "@nx/jest": "22.6.0",
    "@nx/js": "22.6.0",
    "@nx/node": "22.6.0",
    "@nx/vite": "22.6.0",
    "@nx/vitest": "22.6.0",
    "@nx/vue": "^22.6.0",
    "@nx/web": "22.6.0",
    "@nx/webpack": "22.6.0",
    "@nx/workspace": "22.6.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "~4.0.0",
    "@vitest/ui": "~4.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^9.16.1",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.6.0",
    "prettier": "~3.6.2",
    "react-refresh": "^0.10.0",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vitest": "~4.0.0",
    "vue-tsc": "^2.2.8",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "graphql": "^16.13.1",
    "graphql-http": "^1.22.4",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "^2.0.0-rc.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  }
}
