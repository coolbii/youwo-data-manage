{
  "name": "api-java",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "api-java/src",
  "projectType": "application",
  "tags": ["scope:api", "stack:spring-boot"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/target"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mvn -f api-java/pom.xml clean package -DskipTests"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mvn -f api-java/pom.xml spring-boot:run"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mvn -f api-java/pom.xml test"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mvn -f api-java/pom.xml checkstyle:check"
      }
    },
    "db-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mvn -f api-java/pom.xml flyway:migrate"
      }
    },
    "db-import": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "scripts/db-import.sh --table={args.table} --csv={args.csv}"
      }
    },
    "db-ddl-draft": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p api-java/target/generated-ddl && rm -f api-java/target/generated-ddl/jpa-create.sql && mvn -f api-java/pom.xml -Dspring-boot.run.profiles=ddl-draft -Dspring-boot.run.jvmArguments='-Dspring.main.web-application-type=none' spring-boot:run && if command -v sqlfluff >/dev/null 2>&1; then sqlfluff fix --dialect postgres api-java/target/generated-ddl/jpa-create.sql || true; else echo '[db-ddl-draft] sqlfluff not found; skip formatting'; fi"
      }
    },
    "graphql-codegen": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mvn -f api-java/pom.xml -DskipTests -Dexec.mainClass=com.youwo.api.graphql.SchemaExportMain compile org.codehaus.mojo:exec-maven-plugin:3.5.0:java"
      }
    },
    "graphql-drift-check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "nx run api-java:graphql-codegen && git diff --exit-code -- api-java/src/main/resources/graphql/schema.graphqls"
      }
    }
  }
}
